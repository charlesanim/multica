{
  "name": "multica",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "pnpm --filter @multica/web dev",
    "build": "pnpm --filter @multica/web build",
    "typecheck": "pnpm --filter @multica/web typecheck",
    "test": "pnpm --filter @multica/web test",
    "lint": "pnpm --filter @multica/web lint",
    "clean": "pnpm --filter @multica/web clean && rm -rf node_modules"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@types/react": "catalog:",
      "@types/react-dom": "catalog:",
      "vite": "8.0.5",
      "path-to-regexp": "8.4.2",
      "hono": "4.12.12",
      "@hono/node-server": "1.19.13",
      "brace-expansion@^5.0.0": "5.0.5",
      "picomatch@^2.3.0": "2.3.2",
      "picomatch@^4.0.0": "4.0.4"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "typescript": "catalog:"
  }
}
